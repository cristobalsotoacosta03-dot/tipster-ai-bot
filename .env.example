# ===========================================
# TELEGRAM CONFIGURATION
# ===========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_ID=your_admin_user_id_here
TELEGRAM_VIP_GROUP_ID=-100xxxxxxxxxx

# ===========================================
# ANTHROPIC API (Claude) — optional
# Without this, /analisis stays disabled but the rest of the bot
# (channel, VIP checkout via Stripe) works fine. This is a separate
# product/billing from a Claude Pro subscription.
# ===========================================
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ===========================================
# STRIPE PAYMENTS
# ===========================================
STRIPE_API_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_ID_MONTHLY=price_your_monthly_price_id
STRIPE_PRICE_ID_YEARLY=price_your_yearly_price_id

# ===========================================
# FOOTBALL DATA API
# ===========================================
# Free tier (100 req/day) via a direct account at dashboard.api-football.com
# (NOT a RapidAPI key - different auth scheme). Real league/season and
# recent fixtures are resolved dynamically per team - see src/data/stats_fetcher.py.
API_FOOTBALL_KEY=your_api_football_key_here

# Optional free fallback sources, used only when API-Football can't find one
# of the two teams (e.g. free-tier quota exhausted, or a team outside
# API-Football's coverage). Both require a free personal account - leave
# unset to disable, nothing else changes.
# Sign up: https://www.football-data.org/client/register
FOOTBALL_DATA_ORG_KEY=
# Sign up: https://www.thesportsdb.com/free_sports_api (free tier requires
# a personal key from your account profile page)
THESPORTSDB_API_KEY=

# Optional: real bookmaker odds to compare against the model's confidence
# (The Odds API, free tier: 500 req/month, no card required). Leave unset
# to disable - nothing else changes.
# Sign up: https://the-odds-api.com/
ODDS_API_KEY=

# Optional: Telegram tipster-consensus reader (separate user account, not
# the bot - see scripts/telegram_consensus_login.py). Get api_id/api_hash
# free at https://my.telegram.org, then run the login script once locally
# to get TELEGRAM_CONSENSUS_SESSION. Treat the session string like a password.
TELEGRAM_CONSENSUS_API_ID=
TELEGRAM_CONSENSUS_API_HASH=
TELEGRAM_CONSENSUS_SESSION=

# ===========================================
# REDIS CACHE (Upstash)
# ===========================================
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token-here

# ===========================================
# APPLICATION SETTINGS
# ===========================================
ENVIRONMENT=development
LOG_LEVEL=INFO
CACHE_TTL_HOURS=6
MAX_ANALYSIS_PER_DAY=50
FREE_TIPS_PER_DAY=2

# ===========================================
# MONETIZATION
# ===========================================
VIP_MONTHLY_PRICE_EUR=29.99
VIP_YEARLY_PRICE_EUR=299.00
CURRENCY=EUR